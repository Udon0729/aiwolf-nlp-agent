web_socket:
  url: ws://127.0.0.1:8080/ws
  token:
  auto_reconnect: false

agent:
  num: 5
  team: kanolab
  kill_on_timeout: true

path:
  random_talk: ./resource/2019071_44011_AIWolfTalkLogs.txt

llm:
  type: openai  # or 'local'
  model: gpt-4o # or 'meta-llama/Llama-3.2-3B-Instruct' etc.
  temperature: 0.7
  # Local specific
  local_model_path: ./models/my-finetuned-model
  device_map: auto
  formatter: chat_template # 'chat_template' (default) or 'simple'

log:
  console_output: true
  file_output: true
  output_dir: ./log
  level: debug

  request:
    name: false
    initialize: false
    daily_initialize: false
    whisper: true
    talk: true
    daily_finish: false
    divine: true
    guard: true
    vote: true
    attack: true
    finish: false
